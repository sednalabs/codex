    },
    "cwd": {
      "type": "string"
    },
    "parsedCmd": {
      "items": {
        "$ref": "#/$defs/ParsedCommand"
      },
      "type": "array"
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "conversationId",
    "callId",
