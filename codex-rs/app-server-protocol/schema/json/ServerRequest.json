          "$ref": "#/$defs/McpElicitationMultiSelectEnumSchema"
        },
        {
          "$ref": "#/$defs/McpElicitationLegacyTitledEnumSchema"
        }
      ]
    },
    "McpElicitationLegacyTitledEnumSchema": {
