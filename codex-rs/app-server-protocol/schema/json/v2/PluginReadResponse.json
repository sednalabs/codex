{
  "$defs": {
    "AbsolutePathBuf": {
      "description": "A path that is guaranteed to be absolute and normalized (though it is not\nguaranteed to be canonicalized or exist on the filesystem).\n\nIMPORTANT: When deserializing an `AbsolutePathBuf`, a base path must be set\nusing [AbsolutePathBufGuard::new]. If no base path is set, the\ndeserialization will fail unless the path being deserialized is already\nabsolute.",
      "type": "string"
    },
    "AppSummary": {
      "description": "EXPERIMENTAL - app metadata summary for plugin responses.",
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "installUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "needsAuth": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "name",
        "needsAuth"
      ],
      "type": "object"
    },
    "PluginAuthPolicy": {
      "enum": [
        "ON_INSTALL",
        "ON_USE"
      ],
      "type": "string"
    },
    "PluginDetail": {
      "properties": {
        "apps": {
          "items": {
            "$ref": "#/$defs/AppSummary"
          },
          "type": "array"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "marketplaceName": {
          "type": "string"
        },
        "marketplacePath": {
          "$ref": "#/$defs/AbsolutePathBuf"
        },
        "mcpServers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "skills": {
          "items": {
            "$ref": "#/$defs/SkillSummary"
          },
          "type": "array"
        },
        "summary": {
          "$ref": "#/$defs/PluginSummary"
        }
      },
      "required": [
        "marketplaceName",
        "marketplacePath",
        "summary",
        "skills",
        "apps",
        "mcpServers"
      ],
      "type": "object"
    },
    "PluginInstallPolicy": {
      "enum": [
        "NOT_AVAILABLE",
        "AVAILABLE",
        "INSTALLED_BY_DEFAULT"
      ],
      "type": "string"
    },
    "PluginInterface": {
      "properties": {
        "brandColor": {
          "type": [
            "string",
            "null"
          ]
        },
        "capabilities": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "category": {
          "type": [
            "string",
            "null"
          ]
        },
        "composerIcon": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsolutePathBuf"
            },
            {
              "type": "null"
            }
          ]
        },
        "defaultPrompt": {
          "description": "Starter prompts for the plugin. Capped at 3 entries with a maximum of\n128 characters per entry.",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "developerName": {
          "type": [
            "string",
            "null"
          ]
        },
        "displayName": {
          "type": [
            "string",
            "null"
          ]
        },
        "logo": {
          "anyOf": [
            {
              "$ref": "#/$defs/AbsolutePathBuf"
            },
            {
              "type": "null"
            }
          ]
        },
        "longDescription": {
          "type": [
            "string",
            "null"
          ]
        },
        "privacyPolicyUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "screenshots": {
          "items": {
            "$ref": "#/$defs/AbsolutePathBuf"
          },
          "type": "array"
        },
        "shortDescription": {
          "type": [
            "string",
            "null"
          ]
        },
        "termsOfServiceUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "websiteUrl": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "capabilities",
        "screenshots"
      ],
      "type": "object"
    },
    "PluginSource": {
      "oneOf": [
        {
          "properties": {
            "path": {
              "$ref": "#/$defs/AbsolutePathBuf"
            },
            "type": {
              "const": "local",
              "title": "LocalPluginSourceType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "path"
          ],
          "title": "LocalPluginSource",
          "type": "object"
        }
      ]
    },
    "PluginSummary": {
      "properties": {
        "authPolicy": {
          "$ref": "#/$defs/PluginAuthPolicy"
        },
        "enabled": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "installPolicy": {
          "$ref": "#/$defs/PluginInstallPolicy"
        },
        "installed": {
          "type": "boolean"
        },
        "interface": {
          "anyOf": [
            {
              "$ref": "#/$defs/PluginInterface"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/PluginSource"
        }
      },
      "required": [
        "id",
        "name",
        "source",
        "installed",
        "enabled",
        "installPolicy",
        "authPolicy"
      ],
      "type": "object"
    },
    "SkillInterface": {
      "properties": {
        "brandColor": {
          "type": [
            "string",
            "null"
          ]
        },
        "defaultPrompt": {
          "type": [
            "string",
            "null"
          ]
        },
        "displayName": {
          "type": [
            "string",
            "null"
          ]
        },
        "iconLarge": {
          "type": [
            "string",
            "null"
          ]
        },
        "iconSmall": {
          "type": [
            "string",
            "null"
          ]
        },
        "shortDescription": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "SkillSummary": {
      "properties": {
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "interface": {
          "anyOf": [
            {
              "$ref": "#/$defs/SkillInterface"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "shortDescription": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "description",
        "path",
        "enabled"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "plugin": {
      "$ref": "#/$defs/PluginDetail"
    }
  },
  "required": [
    "plugin"
  ],
  "title": "PluginReadResponse",
  "type": "object"
}