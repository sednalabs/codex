{
  "$defs": {
    "AbsolutePathBuf": {
      "description": "A path that is guaranteed to be absolute and normalized (though it is not\nguaranteed to be canonicalized or exist on the filesystem).\n\nIMPORTANT: When deserializing an `AbsolutePathBuf`, a base path must be set\nusing [AbsolutePathBufGuard::new]. If no base path is set, the\ndeserialization will fail unless the path being deserialized is already\nabsolute.",
      "type": "string"
    },
    "CommandExecTerminalSize": {
      "description": "PTY size in character cells for `command/exec` PTY sessions.",
      "properties": {
        "cols": {
          "description": "Terminal width in character cells.",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "rows": {
          "description": "Terminal height in character cells.",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "rows",
        "cols"
      ],
      "type": "object"
    },
    "FileSystemAccessMode": {
      "enum": [
        "read",
        "write",
        "none"
      ],
      "type": "string"
    },
    "FileSystemPath": {
      "oneOf": [
        {
          "properties": {
            "path": {
              "$ref": "#/$defs/AbsolutePathBuf"
            },
            "type": {
              "const": "path",
              "title": "PathFileSystemPathType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "path"
          ],
          "title": "PathFileSystemPath",
          "type": "object"
        },
        {
          "properties": {
            "pattern": {
              "type": "string"
            },
            "type": {
              "const": "glob_pattern",
              "title": "GlobPatternFileSystemPathType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "pattern"
          ],
          "title": "GlobPatternFileSystemPath",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "const": "special",
              "title": "SpecialFileSystemPathType",
              "type": "string"
            },
            "value": {
              "$ref": "#/$defs/FileSystemSpecialPath"
            }
          },
          "required": [
            "type",
            "value"
          ],
          "title": "SpecialFileSystemPath",
          "type": "object"
        }
      ]
    },
    "FileSystemSandboxEntry": {
      "properties": {
        "access": {
          "$ref": "#/$defs/FileSystemAccessMode"
        },
        "path": {
          "$ref": "#/$defs/FileSystemPath"
        }
      },
      "required": [
        "path",
        "access"
      ],
      "type": "object"
    },
    "FileSystemSpecialPath": {
      "oneOf": [
        {
          "properties": {
            "kind": {
              "const": "root",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "title": "RootFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "minimal",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "title": "MinimalFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "current_working_directory",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "title": "CurrentWorkingDirectoryFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "project_roots",
              "type": "string"
            },
            "subpath": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind"
          ],
          "title": "KindFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "tmpdir",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "title": "TmpdirFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "slash_tmp",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "title": "SlashTmpFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "unknown",
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "subpath": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "path"
          ],
          "type": "object"
        }
      ]
    },
    "NetworkAccess": {
      "enum": [
        "restricted",
        "enabled"
      ],
      "type": "string"
    },
    "PermissionProfile": {
      "oneOf": [
        {
          "description": "Codex owns sandbox construction for this profile.",
          "properties": {
            "fileSystem": {
              "$ref": "#/$defs/PermissionProfileFileSystemPermissions"
            },
            "network": {
              "$ref": "#/$defs/PermissionProfileNetworkPermissions"
            },
            "type": {
              "const": "managed",
              "title": "ManagedPermissionProfileType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "network",
            "fileSystem"
          ],
          "title": "ManagedPermissionProfile",
          "type": "object"
        },
        {
          "description": "Do not apply an outer sandbox.",
          "properties": {
            "type": {
              "const": "disabled",
              "title": "DisabledPermissionProfileType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "DisabledPermissionProfile",
          "type": "object"
        },
        {
          "description": "Filesystem isolation is enforced by an external caller.",
          "properties": {
            "network": {
              "$ref": "#/$defs/PermissionProfileNetworkPermissions"
            },
            "type": {
              "const": "external",
              "title": "ExternalPermissionProfileType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "network"
          ],
          "title": "ExternalPermissionProfile",
          "type": "object"
        }
      ]
    },
    "PermissionProfileFileSystemPermissions": {
      "oneOf": [
        {
          "properties": {
            "entries": {
              "items": {
                "$ref": "#/$defs/FileSystemSandboxEntry"
              },
              "type": "array"
            },
            "globScanMaxDepth": {
              "format": "uint",
              "minimum": 1,
              "type": [
                "integer",
                "null"
              ]
            },
            "type": {
              "const": "restricted",
              "title": "RestrictedPermissionProfileFileSystemPermissionsType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "entries"
          ],
          "title": "RestrictedPermissionProfileFileSystemPermissions",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "const": "unrestricted",
              "title": "UnrestrictedPermissionProfileFileSystemPermissionsType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "UnrestrictedPermissionProfileFileSystemPermissions",
          "type": "object"
        }
      ]
    },
    "PermissionProfileNetworkPermissions": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "type": "object"
    },
    "SandboxPolicy": {
      "oneOf": [
        {
          "properties": {
            "type": {
              "const": "dangerFullAccess",
              "title": "DangerFullAccessSandboxPolicyType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "DangerFullAccessSandboxPolicy",
          "type": "object"
        },
        {
          "properties": {
            "networkAccess": {
              "default": false,
              "type": "boolean"
            },
            "type": {
              "const": "readOnly",
              "title": "ReadOnlySandboxPolicyType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "ReadOnlySandboxPolicy",
          "type": "object"
        },
        {
          "properties": {
            "networkAccess": {
              "$ref": "#/$defs/NetworkAccess",
              "default": "restricted"
            },
            "type": {
              "const": "externalSandbox",
              "title": "ExternalSandboxSandboxPolicyType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "ExternalSandboxSandboxPolicy",
          "type": "object"
        },
        {
          "properties": {
            "excludeSlashTmp": {
              "default": false,
              "type": "boolean"
            },
            "excludeTmpdirEnvVar": {
              "default": false,
              "type": "boolean"
            },
            "networkAccess": {
              "default": false,
              "type": "boolean"
            },
            "type": {
              "const": "workspaceWrite",
              "title": "WorkspaceWriteSandboxPolicyType",
              "type": "string"
            },
            "writableRoots": {
              "default": [],
              "items": {
                "$ref": "#/$defs/AbsolutePathBuf"
              },
              "type": "array"
            }
          },
          "required": [
            "type"
          ],
          "title": "WorkspaceWriteSandboxPolicy",
          "type": "object"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Run a standalone command (argv vector) in the server sandbox without\ncreating a thread or turn.\n\nThe final `command/exec` response is deferred until the process exits and is\nsent only after all `command/exec/outputDelta` notifications for that\nconnection have been emitted.",
  "properties": {
    "command": {
      "description": "Command argv vector. Empty arrays are rejected.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "cwd": {
      "description": "Optional working directory. Defaults to the server cwd.",
      "type": [
        "string",
        "null"
      ]
    },
    "disableOutputCap": {
      "description": "Disable stdout/stderr capture truncation for this request.\n\nCannot be combined with `outputBytesCap`.",
      "type": "boolean"
    },
    "disableTimeout": {
      "description": "Disable the timeout entirely for this request.\n\nCannot be combined with `timeoutMs`.",
      "type": "boolean"
    },
    "env": {
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ]
      },
      "description": "Optional environment overrides merged into the server-computed\nenvironment.\n\nMatching names override inherited values. Set a key to `null` to unset\nan inherited variable.",
      "type": [
        "object",
        "null"
      ]
    },
    "outputBytesCap": {
      "description": "Optional per-stream stdout/stderr capture cap in bytes.\n\nWhen omitted, the server default applies. Cannot be combined with\n`disableOutputCap`.",
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "permissionProfile": {
      "anyOf": [
        {
          "$ref": "#/$defs/PermissionProfile"
        },
        {
          "type": "null"
        }
      ],
      "description": "Optional full permissions profile for this command.\n\nDefaults to the user's configured permissions when omitted. Cannot be\ncombined with `sandboxPolicy`."
    },
    "processId": {
      "description": "Optional client-supplied, connection-scoped process id.\n\nRequired for `tty`, `streamStdin`, `streamStdoutStderr`, and follow-up\n`command/exec/write`, `command/exec/resize`, and\n`command/exec/terminate` calls. When omitted, buffered execution gets an\ninternal id that is not exposed to the client.",
      "type": [
        "string",
        "null"
      ]
    },
    "sandboxPolicy": {
      "anyOf": [
        {
          "$ref": "#/$defs/SandboxPolicy"
        },
        {
          "type": "null"
        }
      ],
      "description": "Optional sandbox policy for this command.\n\nUses the same shape as thread/turn execution sandbox configuration and\ndefaults to the user's configured policy when omitted. Cannot be\ncombined with `permissionProfile`."
    },
    "size": {
      "anyOf": [
        {
          "$ref": "#/$defs/CommandExecTerminalSize"
        },
        {
          "type": "null"
        }
      ],
      "description": "Optional initial PTY size in character cells. Only valid when `tty` is\ntrue."
    },
    "streamStdin": {
      "description": "Allow follow-up `command/exec/write` requests to write stdin bytes.\n\nRequires a client-supplied `processId`.",
      "type": "boolean"
    },
    "streamStdoutStderr": {
      "description": "Stream stdout/stderr via `command/exec/outputDelta` notifications.\n\nStreamed bytes are not duplicated into the final response and require a\nclient-supplied `processId`.",
      "type": "boolean"
    },
    "timeoutMs": {
      "description": "Optional timeout in milliseconds.\n\nWhen omitted, the server default applies. Cannot be combined with\n`disableTimeout`.",
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "tty": {
      "description": "Enable PTY mode.\n\nThis implies `streamStdin` and `streamStdoutStderr`.",
      "type": "boolean"
    }
  },
  "required": [
    "command"
  ],
  "title": "CommandExecParams",
  "type": "object"
}