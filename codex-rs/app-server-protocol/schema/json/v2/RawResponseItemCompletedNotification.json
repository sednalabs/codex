        {
          "const": "commentary",
          "description": "Mid-turn assistant text (for example preamble/progress narration).\n\nAdditional tool calls or assistant output may follow before turn\ncompletion.",
          "type": "string"
        },
        {
          "const": "final_answer",
          "description": "The assistant's terminal answer text for the current turn.",
          "type": "string"
