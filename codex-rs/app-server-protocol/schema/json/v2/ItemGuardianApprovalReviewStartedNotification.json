{
  "$defs": {
    "GuardianApprovalReview": {
      "description": "[UNSTABLE] Temporary guardian approval review payload used by\n`item/autoApprovalReview/*` notifications. This shape is expected to change\nsoon.",
      "properties": {
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "riskLevel": {
          "anyOf": [
            {
              "$ref": "#/$defs/GuardianRiskLevel"
            },
            {
              "type": "null"
            }
          ]
        },
        "riskScore": {
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/GuardianApprovalReviewStatus"
        }
      },
      "required": [
        "status"
      ],
      "type": "object"
    },
    "GuardianApprovalReviewAction": {
      "oneOf": [
        {
          "properties": {
            "command": {
              "type": "string"
            },
            "cwd": {
              "type": "string"
            },
            "source": {
              "$ref": "#/$defs/GuardianCommandSource"
            },
            "type": {
              "const": "command",
              "title": "CommandGuardianApprovalReviewActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "source",
            "command",
            "cwd"
          ],
          "title": "CommandGuardianApprovalReviewAction",
          "type": "object"
        },
        {
          "properties": {
            "argv": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "cwd": {
              "type": "string"
            },
            "program": {
              "type": "string"
            },
            "source": {
              "$ref": "#/$defs/GuardianCommandSource"
            },
            "type": {
              "const": "execve",
              "title": "ExecveGuardianApprovalReviewActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "source",
            "program",
            "argv",
            "cwd"
          ],
          "title": "ExecveGuardianApprovalReviewAction",
          "type": "object"
        },
        {
          "properties": {
            "cwd": {
              "type": "string"
            },
            "files": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "type": {
              "const": "applyPatch",
              "title": "ApplyPatchGuardianApprovalReviewActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "cwd",
            "files"
          ],
          "title": "ApplyPatchGuardianApprovalReviewAction",
          "type": "object"
        },
        {
          "properties": {
            "host": {
              "type": "string"
            },
            "port": {
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0,
              "type": "integer"
            },
            "protocol": {
              "$ref": "#/$defs/NetworkApprovalProtocol"
            },
            "target": {
              "type": "string"
            },
            "type": {
              "const": "networkAccess",
              "title": "NetworkAccessGuardianApprovalReviewActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "target",
            "host",
            "protocol",
            "port"
          ],
          "title": "NetworkAccessGuardianApprovalReviewAction",
          "type": "object"
        },
        {
          "properties": {
            "connectorId": {
              "type": [
                "string",
                "null"
              ]
            },
            "connectorName": {
              "type": [
                "string",
                "null"
              ]
            },
            "server": {
              "type": "string"
            },
            "toolName": {
              "type": "string"
            },
            "toolTitle": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "const": "mcpToolCall",
              "title": "McpToolCallGuardianApprovalReviewActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "server",
            "toolName"
          ],
          "title": "McpToolCallGuardianApprovalReviewAction",
          "type": "object"
        },
        {
          "properties": {
            "raw": true,
            "type": {
              "const": "unknown",
              "title": "UnknownGuardianApprovalReviewActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "raw"
          ],
          "title": "UnknownGuardianApprovalReviewAction",
          "type": "object"
        }
      ]
    },
    "GuardianApprovalReviewStatus": {
      "description": "[UNSTABLE] Lifecycle state for a guardian approval review.",
      "enum": [
        "inProgress",
        "approved",
        "denied",
        "aborted"
      ],
      "type": "string"
    },
    "GuardianCommandSource": {
      "enum": [
        "shell",
        "unifiedExec"
      ],
      "type": "string"
    },
    "GuardianRiskLevel": {
      "description": "[UNSTABLE] Risk level assigned by guardian approval review.",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "type": "string"
    },
    "NetworkApprovalProtocol": {
      "enum": [
        "http",
        "https",
        "socks5Tcp",
        "socks5Udp"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "[UNSTABLE] Temporary notification payload for guardian automatic approval\nreview. This shape is expected to change soon.\n\nTODO(ccunningham): Attach guardian review state to the reviewed tool item's\nlifecycle instead of sending separate standalone review notifications so the\napp-server API can persist and replay review state via `thread/read`.",
  "properties": {
    "action": {
      "$ref": "#/$defs/GuardianApprovalReviewAction"
    },
    "review": {
      "$ref": "#/$defs/GuardianApprovalReview"
    },
    "targetItemId": {
      "type": "string"
    },
    "threadId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    }
  },
  "required": [
    "threadId",
    "turnId",
    "targetItemId",
    "review",
    "action"
  ],
  "title": "ItemGuardianApprovalReviewStartedNotification",
  "type": "object"
}