{
  "$defs": {
    "ByteRange": {
      "properties": {
        "end": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "start": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "start",
        "end"
      ],
      "type": "object"
    },
    "CollabAgentState": {
      "properties": {
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/CollabAgentStatus"
        }
      },
      "required": [
        "status"
      ],
      "type": "object"
    },
    "CollabAgentStatus": {
      "enum": [
        "pendingInit",
        "running",
        "interrupted",
        "completed",
        "errored",
        "shutdown",
        "notFound"
      ],
      "type": "string"
    },
    "CollabAgentTool": {
      "enum": [
        "spawnAgent",
        "sendInput",
        "resumeAgent",
        "wait",
        "closeAgent"
      ],
      "type": "string"
    },
    "CollabAgentToolCallStatus": {
      "enum": [
        "inProgress",
        "completed",
        "failed"
      ],
      "type": "string"
    },
    "CommandAction": {
      "oneOf": [
        {
          "properties": {
            "command": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "type": {
              "const": "read",
              "title": "ReadCommandActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "command",
            "name",
            "path"
          ],
          "title": "ReadCommandAction",
          "type": "object"
        },
        {
          "properties": {
            "command": {
              "type": "string"
            },
            "path": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "const": "listFiles",
              "title": "ListFilesCommandActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "command"
          ],
          "title": "ListFilesCommandAction",
          "type": "object"
        },
        {
          "properties": {
            "command": {
              "type": "string"
            },
            "path": {
              "type": [
                "string",
                "null"
              ]
            },
            "query": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "const": "search",
              "title": "SearchCommandActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "command"
          ],
          "title": "SearchCommandAction",
          "type": "object"
        },
        {
          "properties": {
            "command": {
              "type": "string"
            },
            "type": {
              "const": "unknown",
              "title": "UnknownCommandActionType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "command"
          ],
          "title": "UnknownCommandAction",
          "type": "object"
        }
      ]
    },
    "CommandExecutionSource": {
      "enum": [
        "agent",
        "userShell",
        "unifiedExecStartup",
        "unifiedExecInteraction"
      ],
      "type": "string"
    },
    "CommandExecutionStatus": {
      "enum": [
        "inProgress",
        "completed",
        "failed",
        "declined"
      ],
      "type": "string"
    },
    "DynamicToolCallOutputContentItem": {
      "oneOf": [
        {
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "const": "inputText",
              "title": "InputTextDynamicToolCallOutputContentItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "title": "InputTextDynamicToolCallOutputContentItem",
          "type": "object"
        },
        {
          "properties": {
            "imageUrl": {
              "type": "string"
            },
            "type": {
              "const": "inputImage",
              "title": "InputImageDynamicToolCallOutputContentItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "imageUrl"
          ],
          "title": "InputImageDynamicToolCallOutputContentItem",
          "type": "object"
        }
      ]
    },
    "DynamicToolCallStatus": {
      "enum": [
        "inProgress",
        "completed",
        "failed"
      ],
      "type": "string"
    },
    "FileUpdateChange": {
      "properties": {
        "diff": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/PatchChangeKind"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "kind",
        "diff"
      ],
      "type": "object"
    },
    "HookPromptFragment": {
      "properties": {
        "hookRunId": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "text",
        "hookRunId"
      ],
      "type": "object"
    },
    "McpToolCallError": {
      "properties": {
        "message": {
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "type": "object"
    },
    "McpToolCallResult": {
      "properties": {
        "_meta": true,
        "content": {
          "items": true,
          "type": "array"
        },
        "structuredContent": true
      },
      "required": [
        "content"
      ],
      "type": "object"
    },
    "McpToolCallStatus": {
      "enum": [
        "inProgress",
        "completed",
        "failed"
      ],
      "type": "string"
    },
    "MemoryCitation": {
      "properties": {
        "entries": {
          "items": {
            "$ref": "#/$defs/MemoryCitationEntry"
          },
          "type": "array"
        },
        "threadIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "entries",
        "threadIds"
      ],
      "type": "object"
    },
    "MemoryCitationEntry": {
      "properties": {
        "lineEnd": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "lineStart": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "note": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "lineStart",
        "lineEnd",
        "note"
      ],
      "type": "object"
    },
    "MessagePhase": {
      "description": "Classifies an assistant message as interim commentary or final answer text.\n\nProviders do not emit this consistently, so callers must treat `None` as\n\"phase unknown\" and keep compatibility behavior for legacy models.",
      "oneOf": [
        {
          "const": "commentary",
          "description": "Mid-turn assistant text (for example preamble/progress narration).\n\nAdditional tool calls or assistant output may follow before turn\ncompletion.",
          "type": "string"
        },
        {
          "const": "final_answer",
          "description": "The assistant's terminal answer text for the current turn.",
          "type": "string"
        }
      ]
    },
    "PatchApplyStatus": {
      "enum": [
        "inProgress",
        "completed",
        "failed",
        "declined"
      ],
      "type": "string"
    },
    "PatchChangeKind": {
      "oneOf": [
        {
          "properties": {
            "type": {
              "const": "add",
              "title": "AddPatchChangeKindType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "AddPatchChangeKind",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "const": "delete",
              "title": "DeletePatchChangeKindType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "DeletePatchChangeKind",
          "type": "object"
        },
        {
          "properties": {
            "move_path": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "const": "update",
              "title": "UpdatePatchChangeKindType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "UpdatePatchChangeKind",
          "type": "object"
        }
      ]
    },
    "ReasoningEffort": {
      "description": "See https://platform.openai.com/docs/guides/reasoning?api-mode=responses#get-started-with-reasoning",
      "enum": [
        "none",
        "minimal",
        "low",
        "medium",
        "high",
        "xhigh"
      ],
      "type": "string"
    },
    "TextElement": {
      "properties": {
        "byteRange": {
          "$ref": "#/$defs/ByteRange",
          "description": "Byte range in the parent `text` buffer that this element occupies."
        },
        "placeholder": {
          "description": "Optional human-readable placeholder for the element, displayed in the UI.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "byteRange"
      ],
      "type": "object"
    },
    "ThreadItem": {
      "oneOf": [
        {
          "properties": {
            "content": {
              "items": {
                "$ref": "#/$defs/UserInput"
              },
              "type": "array"
            },
            "id": {
              "type": "string"
            },
            "type": {
              "const": "userMessage",
              "title": "UserMessageThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "content"
          ],
          "title": "UserMessageThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "fragments": {
              "items": {
                "$ref": "#/$defs/HookPromptFragment"
              },
              "type": "array"
            },
            "id": {
              "type": "string"
            },
            "type": {
              "const": "hookPrompt",
              "title": "HookPromptThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "fragments"
          ],
          "title": "HookPromptThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "id": {
              "type": "string"
            },
            "memoryCitation": {
              "anyOf": [
                {
                  "$ref": "#/$defs/MemoryCitation"
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "phase": {
              "anyOf": [
                {
                  "$ref": "#/$defs/MessagePhase"
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "text": {
              "type": "string"
            },
            "type": {
              "const": "agentMessage",
              "title": "AgentMessageThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "text"
          ],
          "title": "AgentMessageThreadItem",
          "type": "object"
        },
        {
          "description": "EXPERIMENTAL - proposed plan item content. The completed plan item is\nauthoritative and may not match the concatenation of `PlanDelta` text.",
          "properties": {
            "id": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "type": {
              "const": "plan",
              "title": "PlanThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "text"
          ],
          "title": "PlanThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "content": {
              "default": [],
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "id": {
              "type": "string"
            },
            "summary": {
              "default": [],
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "type": {
              "const": "reasoning",
              "title": "ReasoningThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id"
          ],
          "title": "ReasoningThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "aggregatedOutput": {
              "description": "The command's output, aggregated from stdout and stderr.",
              "type": [
                "string",
                "null"
              ]
            },
            "command": {
              "description": "The command to be executed.",
              "type": "string"
            },
            "commandActions": {
              "description": "A best-effort parsing of the command to understand the action(s) it will perform.\nThis returns a list of CommandAction objects because a single shell command may\nbe composed of many commands piped together.",
              "items": {
                "$ref": "#/$defs/CommandAction"
              },
              "type": "array"
            },
            "cwd": {
              "description": "The command's working directory.",
              "type": "string"
            },
            "durationMs": {
              "description": "The duration of the command execution in milliseconds.",
              "format": "int64",
              "type": [
                "integer",
                "null"
              ]
            },
            "exitCode": {
              "description": "The command's exit code.",
              "format": "int32",
              "type": [
                "integer",
                "null"
              ]
            },
            "id": {
              "type": "string"
            },
            "processId": {
              "description": "Identifier for the underlying PTY process (when available).",
              "type": [
                "string",
                "null"
              ]
            },
            "source": {
              "$ref": "#/$defs/CommandExecutionSource",
              "default": "agent"
            },
            "status": {
              "$ref": "#/$defs/CommandExecutionStatus"
            },
            "type": {
              "const": "commandExecution",
              "title": "CommandExecutionThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "command",
            "cwd",
            "status",
            "commandActions"
          ],
          "title": "CommandExecutionThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "changes": {
              "items": {
                "$ref": "#/$defs/FileUpdateChange"
              },
              "type": "array"
            },
            "id": {
              "type": "string"
            },
            "status": {
              "$ref": "#/$defs/PatchApplyStatus"
            },
            "type": {
              "const": "fileChange",
              "title": "FileChangeThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "changes",
            "status"
          ],
          "title": "FileChangeThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "arguments": true,
            "durationMs": {
              "description": "The duration of the MCP tool call in milliseconds.",
              "format": "int64",
              "type": [
                "integer",
                "null"
              ]
            },
            "error": {
              "anyOf": [
                {
                  "$ref": "#/$defs/McpToolCallError"
                },
                {
                  "type": "null"
                }
              ]
            },
            "id": {
              "type": "string"
            },
            "result": {
              "anyOf": [
                {
                  "$ref": "#/$defs/McpToolCallResult"
                },
                {
                  "type": "null"
                }
              ]
            },
            "server": {
              "type": "string"
            },
            "status": {
              "$ref": "#/$defs/McpToolCallStatus"
            },
            "tool": {
              "type": "string"
            },
            "type": {
              "const": "mcpToolCall",
              "title": "McpToolCallThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "server",
            "tool",
            "status",
            "arguments"
          ],
          "title": "McpToolCallThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "arguments": true,
            "contentItems": {
              "items": {
                "$ref": "#/$defs/DynamicToolCallOutputContentItem"
              },
              "type": [
                "array",
                "null"
              ]
            },
            "durationMs": {
              "description": "The duration of the dynamic tool call in milliseconds.",
              "format": "int64",
              "type": [
                "integer",
                "null"
              ]
            },
            "id": {
              "type": "string"
            },
            "status": {
              "$ref": "#/$defs/DynamicToolCallStatus"
            },
            "success": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "tool": {
              "type": "string"
            },
            "type": {
              "const": "dynamicToolCall",
              "title": "DynamicToolCallThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "tool",
            "arguments",
            "status"
          ],
          "title": "DynamicToolCallThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "agentsStates": {
              "additionalProperties": {
                "$ref": "#/$defs/CollabAgentState"
              },
              "description": "Last known status of the target agents, when available.",
              "type": "object"
            },
            "id": {
              "description": "Unique identifier for this collab tool call.",
              "type": "string"
            },
            "model": {
              "description": "Model requested for the spawned agent, when applicable.",
              "type": [
                "string",
                "null"
              ]
            },
            "prompt": {
              "description": "Prompt text sent as part of the collab tool call, when available.",
              "type": [
                "string",
                "null"
              ]
            },
            "reasoningEffort": {
              "anyOf": [
                {
                  "$ref": "#/$defs/ReasoningEffort"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Reasoning effort requested for the spawned agent, when applicable."
            },
            "receiverThreadIds": {
              "description": "Thread ID of the receiving agent, when applicable. In case of spawn operation,\nthis corresponds to the newly spawned agent.",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "senderThreadId": {
              "description": "Thread ID of the agent issuing the collab request.",
              "type": "string"
            },
            "status": {
              "$ref": "#/$defs/CollabAgentToolCallStatus",
              "description": "Current status of the collab tool call."
            },
            "timedOut": {
              "description": "Whether a wait call completed due to timeout.",
              "type": "boolean"
            },
            "tool": {
              "$ref": "#/$defs/CollabAgentTool",
              "description": "Name of the collab tool that was invoked."
            },
            "type": {
              "const": "collabAgentToolCall",
              "title": "CollabAgentToolCallThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "tool",
            "status",
            "senderThreadId",
            "receiverThreadIds",
            "timedOut",
            "agentsStates"
          ],
          "title": "CollabAgentToolCallThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "action": {
              "anyOf": [
                {
                  "$ref": "#/$defs/WebSearchAction"
                },
                {
                  "type": "null"
                }
              ]
            },
            "id": {
              "type": "string"
            },
            "query": {
              "type": "string"
            },
            "type": {
              "const": "webSearch",
              "title": "WebSearchThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "query"
          ],
          "title": "WebSearchThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "id": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "type": {
              "const": "imageView",
              "title": "ImageViewThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "path"
          ],
          "title": "ImageViewThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "id": {
              "type": "string"
            },
            "result": {
              "type": "string"
            },
            "revisedPrompt": {
              "type": [
                "string",
                "null"
              ]
            },
            "savedPath": {
              "type": [
                "string",
                "null"
              ]
            },
            "status": {
              "type": "string"
            },
            "type": {
              "const": "imageGeneration",
              "title": "ImageGenerationThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "status",
            "result"
          ],
          "title": "ImageGenerationThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "id": {
              "type": "string"
            },
            "review": {
              "type": "string"
            },
            "type": {
              "const": "enteredReviewMode",
              "title": "EnteredReviewModeThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "review"
          ],
          "title": "EnteredReviewModeThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "id": {
              "type": "string"
            },
            "review": {
              "type": "string"
            },
            "type": {
              "const": "exitedReviewMode",
              "title": "ExitedReviewModeThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id",
            "review"
          ],
          "title": "ExitedReviewModeThreadItem",
          "type": "object"
        },
        {
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "const": "contextCompaction",
              "title": "ContextCompactionThreadItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "id"
          ],
          "title": "ContextCompactionThreadItem",
          "type": "object"
        }
      ]
    },
    "UserInput": {
      "oneOf": [
        {
          "properties": {
            "text": {
              "type": "string"
            },
            "text_elements": {
              "default": [],
              "description": "UI-defined spans within `text` used to render or persist special elements.",
              "items": {
                "$ref": "#/$defs/TextElement"
              },
              "type": "array"
            },
            "type": {
              "const": "text",
              "title": "TextUserInputType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "title": "TextUserInput",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "const": "image",
              "title": "ImageUserInputType",
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "url"
          ],
          "title": "ImageUserInput",
          "type": "object"
        },
        {
          "properties": {
            "path": {
              "type": "string"
            },
            "type": {
              "const": "localImage",
              "title": "LocalImageUserInputType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "path"
