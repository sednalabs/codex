{
  "$defs": {
    "AbsolutePathBuf": {
      "description": "A path that is guaranteed to be absolute and normalized (though it is not\nguaranteed to be canonicalized or exist on the filesystem).\n\nIMPORTANT: When deserializing an `AbsolutePathBuf`, a base path must be set\nusing [AbsolutePathBufGuard::new]. If no base path is set, the\ndeserialization will fail unless the path being deserialized is already\nabsolute.",
      "type": "string"
    },
    "ConfigLayerMetadata": {
      "properties": {
        "name": {
          "$ref": "#/$defs/ConfigLayerSource"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "ConfigLayerSource": {
      "oneOf": [
        {
          "description": "Managed preferences layer delivered by MDM (macOS only).",
          "properties": {
            "domain": {
              "type": "string"
            },
            "key": {
              "type": "string"
            },
            "type": {
              "const": "mdm",
              "title": "MdmConfigLayerSourceType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "domain",
            "key"
          ],
          "title": "MdmConfigLayerSource",
          "type": "object"
        },
        {
          "description": "Managed config layer from a file (usually `managed_config.toml`).",
          "properties": {
            "file": {
              "$ref": "#/$defs/AbsolutePathBuf",
              "description": "This is the path to the system config.toml file, though it is not\nguaranteed to exist."
            },
            "type": {
              "const": "system",
              "title": "SystemConfigLayerSourceType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "file"
          ],
          "title": "SystemConfigLayerSource",
          "type": "object"
        },
        {
          "description": "User config layer from $CODEX_HOME/config.toml. This layer is special\nin that it is expected to be:\n- writable by the user\n- generally outside the workspace directory",
          "properties": {
            "file": {
              "$ref": "#/$defs/AbsolutePathBuf",
              "description": "This is the path to the user's config.toml file, though it is not\nguaranteed to exist."
            },
            "type": {
              "const": "user",
              "title": "UserConfigLayerSourceType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "file"
          ],
          "title": "UserConfigLayerSource",
          "type": "object"
        },
        {
          "description": "Path to a .codex/ folder within a project. There could be multiple of\nthese between `cwd` and the project/repo root.",
          "properties": {
            "dotCodexFolder": {
              "$ref": "#/$defs/AbsolutePathBuf"
            },
            "type": {
              "const": "project",
              "title": "ProjectConfigLayerSourceType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "dotCodexFolder"
          ],
          "title": "ProjectConfigLayerSource",
          "type": "object"
        },
        {
          "description": "Session-layer overrides supplied via `-c`/`--config`.",
          "properties": {
            "type": {
              "const": "sessionFlags",
              "title": "SessionFlagsConfigLayerSourceType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "SessionFlagsConfigLayerSource",
          "type": "object"
        },
        {
          "description": "`managed_config.toml` was designed to be a config that was loaded\nas the last layer on top of everything else. This scheme did not quite\nwork out as intended, but we keep this variant as a \"best effort\" while\nwe phase out `managed_config.toml` in favor of `requirements.toml`.",
          "properties": {
            "file": {
              "$ref": "#/$defs/AbsolutePathBuf"
            },
            "type": {
              "const": "legacyManagedConfigTomlFromFile",
              "title": "LegacyManagedConfigTomlFromFileConfigLayerSourceType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "file"
          ],
          "title": "LegacyManagedConfigTomlFromFileConfigLayerSource",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "const": "legacyManagedConfigTomlFromMdm",
              "title": "LegacyManagedConfigTomlFromMdmConfigLayerSourceType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "LegacyManagedConfigTomlFromMdmConfigLayerSource",
          "type": "object"
        }
      ]
    },
    "OverriddenMetadata": {
      "properties": {
        "effectiveValue": true,
        "message": {
          "type": "string"
        },
        "overridingLayer": {
          "$ref": "#/$defs/ConfigLayerMetadata"
        }
      },
      "required": [
        "message",
        "overridingLayer",
        "effectiveValue"
      ],
      "type": "object"
    },
    "WriteStatus": {
      "enum": [
        "ok",
        "okOverridden"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "filePath": {
      "$ref": "#/$defs/AbsolutePathBuf",
      "description": "Canonical path to the config file that was written."
    },
    "overriddenMetadata": {
      "anyOf": [
        {
          "$ref": "#/$defs/OverriddenMetadata"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "$ref": "#/$defs/WriteStatus"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "status",
    "version",
    "filePath"
  ],
  "title": "ConfigWriteResponse",
  "type": "object"
}