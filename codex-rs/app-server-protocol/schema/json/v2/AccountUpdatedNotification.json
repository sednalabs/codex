{
  "$defs": {
    "AuthMode": {
      "description": "Authentication mode for OpenAI-backed providers.",
      "oneOf": [
        {
          "const": "apikey",
          "description": "OpenAI API key provided by the caller and stored by Codex.",
          "type": "string"
        },
        {
          "const": "chatgpt",
          "description": "ChatGPT OAuth managed by Codex (tokens persisted and refreshed by Codex).",
          "type": "string"
        },
        {
          "const": "chatgptAuthTokens",
          "description": "[UNSTABLE] FOR OPENAI INTERNAL USE ONLY - DO NOT USE.\n\nChatGPT auth tokens are supplied by an external host app and are only\nstored in memory. Token refresh must be handled by the external host app.",
          "type": "string"
        }
      ]
    },
    "PlanType": {
      "enum": [
        "free",
        "go",
        "plus",
        "pro",
        "team",
        "self_serve_business_usage_based",
        "business",
        "enterprise_cbp_usage_based",
        "enterprise",
        "edu",
        "unknown"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "authMode": {
      "anyOf": [
        {
          "$ref": "#/$defs/AuthMode"
        },
        {
          "type": "null"
        }
      ]
    },
    "planType": {
      "anyOf": [
        {
          "$ref": "#/$defs/PlanType"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "title": "AccountUpdatedNotification",
  "type": "object"
}