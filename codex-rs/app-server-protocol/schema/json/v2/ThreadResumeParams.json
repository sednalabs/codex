      "required": [
        "command"
      ],
      "type": "object"
    },
    "LocalShellStatus": {
      "enum": [
        "completed",
        "in_progress",
        "incomplete"
      ],
      "type": "string"
    },
    "MessagePhase": {
      "description": "Classifies an assistant message as interim commentary or final answer text.\n\nProviders do not emit this consistently, so callers must treat `None` as\n\"phase unknown\" and keep compatibility behavior for legacy models.",
      "oneOf": [
        {
          "const": "commentary",
          "description": "Mid-turn assistant text (for example preamble/progress narration).\n\nAdditional tool calls or assistant output may follow before turn\ncompletion.",
          "type": "string"
        },
        {
          "const": "final_answer",
          "description": "The assistant's terminal answer text for the current turn.",
          "type": "string"
        }
      ]
    },
    "PermissionProfile": {
      "oneOf": [
        {
          "description": "Codex owns sandbox construction for this profile.",
          "properties": {
            "fileSystem": {
              "$ref": "#/$defs/PermissionProfileFileSystemPermissions"
            },
            "network": {
              "$ref": "#/$defs/PermissionProfileNetworkPermissions"
            },
            "type": {
              "const": "managed",
              "title": "ManagedPermissionProfileType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "network",
            "fileSystem"
          ],
          "title": "ManagedPermissionProfile",
          "type": "object"
        },
        {
          "description": "Do not apply an outer sandbox.",
          "properties": {
            "type": {
              "const": "disabled",
              "title": "DisabledPermissionProfileType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "DisabledPermissionProfile",
          "type": "object"
        },
        {
          "description": "Filesystem isolation is enforced by an external caller.",
          "properties": {
            "network": {
              "$ref": "#/$defs/PermissionProfileNetworkPermissions"
            },
            "type": {
              "const": "external",
              "title": "ExternalPermissionProfileType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "network"
          ],
          "title": "ExternalPermissionProfile",
          "type": "object"
        }
      ]
    },
    "PermissionProfileFileSystemPermissions": {
      "oneOf": [
        {
          "properties": {
            "entries": {
              "items": {
                "$ref": "#/$defs/FileSystemSandboxEntry"
              },
              "type": "array"
            },
            "globScanMaxDepth": {
              "format": "uint",
              "minimum": 1,
              "type": [
                "integer",
                "null"
              ]
            },
            "type": {
              "const": "restricted",
              "title": "RestrictedPermissionProfileFileSystemPermissionsType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "entries"
          ],
          "title": "RestrictedPermissionProfileFileSystemPermissions",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "const": "unrestricted",
              "title": "UnrestrictedPermissionProfileFileSystemPermissionsType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "UnrestrictedPermissionProfileFileSystemPermissions",
          "type": "object"
        }
      ]
    },
    "PermissionProfileNetworkPermissions": {
      "properties": {
        "enabled": {
          "type": "boolean"
